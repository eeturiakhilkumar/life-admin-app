{
  "name": "life-admin-app",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:app": "turbo run dev --filter=app",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:web": "playwright test",
    "test:mobile": "detox test -c ios.sim.debug",
    "build": "turbo run build",
    "build:web": "turbo run build:web --filter=app",
    "pdf:architecture": "python3 scripts/generate_architecture_pdf.py ../docs/life-admin-architecture.md ../docs/life-admin-architecture.pdf",
    "test:wdio:web": "wdio run wdio.conf.web.ts",
    "test:wdio:android": "wdio run wdio.conf.android.ts",
    "test:wdio:ios": "wdio run wdio.conf.ios.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/parser": "^8.46.1",
    "@wdio/appium-service": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "@wdio/visual-service": "^9.2.1",
    "appium": "^3.2.2",
    "detox": "^20.25.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "webdriverio": "^9.27.0"
  }
}
